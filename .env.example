# WhatsApp Bot Configuration
# Copy this file to .env and fill in the values

# The unique ID of the WhatsApp group where customer orders should be forwarded.
# You can get this ID by sending "!groupid" in the group chat using the bot.
# Example: 1234567890@g.us
STAFF_GROUP_ID=

# (Optional) Comma-separated list of phone numbers (without @c.us) 
# that are allowed to use the bot. If empty, everyone can use it.
# Example: 919876543210,919999999999
AUTHORIZED_CUSTOMERS=
